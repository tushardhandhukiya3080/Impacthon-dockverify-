# Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=your_app

# Server Configuration
PORT=3000
SESSION_SECRET=your_very_long_and_random_secret_key_here_minimum_32_characters

# Blockchain Configuration (Sepolia Testnet)
WEB3_PROVIDER_URL=https://sepolia.infura.io/v3/your_infura_project_id
ACCOUNT_ADDRESS=0xYourEthereumAccountAddress
PRIVATE_KEY=your_ethereum_private_key_without_0x_prefix

# IPFS Storage (Pinata)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# 5-Layer Security — optional Python micro-service (Layer 2 invisible watermark)
# Leave blank to disable L2; the app degrades gracefully. See docV/ocr-service/README.md
OCR_SERVICE_URL=

# Document Vault master key — site-gated encryption (REQUIRED to encrypt/open docs).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep SECRET + back it up. If lost, encrypted documents are unrecoverable.
DOC_MASTER_KEY=

# Email Configuration (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. For EMAIL_PASS, use a Gmail App Password (not your regular password)
#    - Go to Google Account Settings > Security > 2-Step Verification > App Passwords
#    - Generate a new app password for "Mail" and use it here
# 4. Never commit the .env file to GitHub (it's in .gitignore)